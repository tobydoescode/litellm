{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "docker:pinDigests"],
  "assignees": ["tobydoescode"],
  "packageRules": [
    {
      "description": "Require review for LiteLLM and Prisma updates",
      "matchPackageNames": ["litellm", "prisma"],
      "automerge": false
    },
    {
      "description": "Group Docker digest updates but require review",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["digest"],
      "groupName": "docker image digests",
      "automerge": false
    },
    {
      "description": "Require review for GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "automerge": false
    },
    {
      "description": "Delay minor updates",
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Delay major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "minimumReleaseAge": "30 days"
    }
  ]
}
